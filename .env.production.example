APP_NAME="Sistem POS Toko Bangunan"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://pos.example.com
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# Isi hanya alamat proxy/load balancer yang benar-benar dipercaya, dipisahkan koma.
# Kosongkan jika aplikasi tidak berada di belakang reverse proxy HTTP.
TRUSTED_PROXIES=

LOG_CHANNEL=daily
LOG_LEVEL=warning
LOG_DAILY_DAYS=30
LOG_DEPRECATIONS_CHANNEL=null

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sistem_informasi_toko_bangunan
DB_USERNAME=pos_produksi
DB_PASSWORD=GANTI_DENGAN_RAHASIA_KUAT

# Wajib non-database agar tidak menambah tabel di luar SQL paten.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false

CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=GANTI_DENGAN_AKUN_SMTP
MAIL_PASSWORD=GANTI_DENGAN_RAHASIA_SMTP
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"
